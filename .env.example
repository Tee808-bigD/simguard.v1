# SimGuard Environment Variables
# NEVER commit the real .env file to git
NAC_API_KEY=your_rapidapi_key_here
NAC_API_HOST=network-as-code.p-eu.rapidapi.com
ANTHROPIC_API_KEY=your_anthropic_key_here
DATABASE_URL=sqlite+aiosqlite:///./simguard.db
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SECRET_KEY=change_me_to_a_random_64_char_string
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_BURST=10
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
MAX_TRANSACTION_AMOUNT=1000000
MAX_PHONE_LENGTH=20
MAX_NAME_LENGTH=100
MAX_PAYLOAD_BYTES=10240
NAC_AUTH_URL=https://nac-authorization-server.p-eu.rapidapi.com
NAC_AUTH_HOST=nac-authorization-server.nokia.rapidapi.com
NAC_METADATA_URL=https://well-known-metadata.p-eu.rapidapi.com
NAC_METADATA_HOST=well-known-metadata.nokia.rapidapi.com
NAC_NV_URL=https://number-verification.p-eu.rapidapi.com
NAC_NV_HOST=number-verification.nokia.rapidapi.com
